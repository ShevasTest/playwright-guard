{
  "name": "playwright-guard",
  "version": "0.1.0",
  "description": "Fail Playwright tests on unexpected browser console errors, page crashes, network failures, and HTTP errors.",
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "console-error",
    "network-error",
    "quality-gate",
    "test-automation"
  ],
  "license": "MIT",
  "author": "ShevasTest contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShevasTest/playwright-guard.git"
  },
  "bugs": {
    "url": "https://github.com/ShevasTest/playwright-guard/issues"
  },
  "homepage": "https://github.com/ShevasTest/playwright-guard#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.45.0 <2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run validate"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
